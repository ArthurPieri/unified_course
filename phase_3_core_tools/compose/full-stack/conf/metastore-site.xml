<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!-- Hive Metastore config for the Phase 3 lakehouse stack.
     JDBC connection is set via SERVICE_OPTS in docker-compose.yml;
     this file carries S3A + warehouse settings only. -->
<configuration>
    <!-- S3A filesystem — MinIO endpoint -->
    <property>
        <name>fs.s3a.endpoint</name>
        <value>http://minio:9000</value>
    </property>
    <property>
        <name>fs.s3a.access.key</name>
        <value>minioadmin</value>
    </property>
    <property>
        <name>fs.s3a.secret.key</name>
        <value>minioadmin</value>
    </property>
    <property>
        <name>fs.s3a.path.style.access</name>
        <value>true</value>
    </property>
    <property>
        <name>fs.s3a.impl</name>
        <value>org.apache.hadoop.fs.s3a.S3AFileSystem</value>
    </property>

    <!-- Warehouse root on MinIO -->
    <property>
        <name>metastore.warehouse.dir</name>
        <value>s3a://lakehouse/</value>
    </property>
</configuration>
