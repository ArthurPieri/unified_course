# Phase 3 full-stack — copy to `.env` and edit before `docker compose up -d`.
# Every var below is read by docker-compose.yml via ${VAR:-default}.

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
LAKEHOUSE_BUCKET=lakehouse

# --- Hive Metastore backend ---
HMS_DB_USER=hive
HMS_DB_PASSWORD=hive
HMS_PORT=9083

# --- Trino ---
TRINO_PORT=8080
TRINO_HEAP=4g

# --- Spark (driver/executor tuning) ---
# Spark config reference: https://spark.apache.org/docs/3.5.3/configuration.html
SPARK_DRIVER_MEM=2g
SPARK_EXECUTOR_MEM=2g

# --- Dagster ---
# Pin your locally built image to the 1.9.x line.
# Releases: https://github.com/dagster-io/dagster/releases
DAGSTER_IMAGE=lakehouse-dagster:1.9
DAGSTER_DB_USER=dagster
DAGSTER_DB_PASSWORD=dagster
DAGSTER_PORT=3000

# --- Metabase ---
METABASE_DB_USER=metabase
METABASE_DB_PASSWORD=metabase
METABASE_PORT=3001
